rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasAdminClaim() {
      return signedIn() && request.auth.token.admin == true;
    }

    function hasAdminEmail() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          '6snailiw@gmail.com',
          'emailgithubb@gmail.com'
        ];
    }

    function isAdmin() {
      return hasAdminClaim() || hasAdminEmail();
    }

    function isActiveOwner(userId) {
      return isOwner(userId)
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.isActive == true;
    }

    function validUserProfileCreate(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'role',
          'isActive',
          'subscription',
          'subscriptionExpiresAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ['user', 'admin']
        && (
          (request.resource.data.role == 'admin' && isAdmin())
          || (request.resource.data.role == 'user' && request.resource.data.isActive == false)
        );
    }

    function validOwnerAutoDeactivate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['isActive'])
        && resource.data.isActive == true
        && request.resource.data.isActive == false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if validUserProfileCreate(userId) || isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && validOwnerAutoDeactivate());
      allow delete: if isAdmin();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isActiveOwner(userId) || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

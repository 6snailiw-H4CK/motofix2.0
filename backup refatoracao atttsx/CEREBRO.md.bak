}

5.3 Tratamento de Erros
// Usar firestoreError.ts para padronização
import { getErrorAction, OperationType } from '@/services/firestoreError'

try {
  await clientRepository.create(userId, client)
} catch (error) {
  const action = getErrorAction(error as FirestoreError, 'create')
  console.error(`Erro ao criar cliente: ${action.message}`)
  toast.error(action.userMessage)
}


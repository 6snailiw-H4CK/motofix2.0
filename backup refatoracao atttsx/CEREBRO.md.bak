5.1 Padrões de Nomenclatura
Componentes React:
// PascalCase, sufixo View para views principais
export const ClientsView: React.FC = () => {}

// Componentes auxiliares: PascalCase simples
export const ClientForm: React.FC<Props> = (props) => {}

// Componentes de layout: sufixo implícito
export const BottomNav: React.FC = () => {}

Hooks Custom:
// Prefixo use, camelCase
export const useAuthProfile = () => { return { user, userProfile } }
export const useClientActions = () => { return { saveClient, deleteClient } }
export const useMaintenanceStats = () => { return { metrics } }

Services e Repositories:
// Sufixo Repository para CRUD genérico
export const clientRepository = { create, update, delete, read }

// Sufixo Service para lógica complexa
export const stripeService = { createCheckoutSession, verifyPayment }
export const alertService = { sendWhatsApp, sendEmail }

// Sufixo Api para integrações externas
export const fiscalApi = { emitirNfe, consultarStatus }

Types e Interfaces:
// PascalCase, prefixo se for type union
interface Client { name: string; bikeModel: string }
type MaintenanceStatus = 'OK' | 'WARNING' | 'OVERDUE'
type OperationType = 'create' | 'update' | 'delete'

Funções Utilitárias:
// camelCase, verbo descritivo
export function getMaintenanceStatus(date: Date): MaintenanceStatus
export function parseBrazilianCurrency(str: string): number
export function calculateDaysUntil(futureDate: Date): number

5.2 Estrutura de Arquivo
Padrão de componente React:
import React from 'react'
import { useHook1 } from '@/hooks/useHook1'
import { useHook2 } from '@/hooks/useHook2'

interface ComponentProps {
  prop1: string
  prop2?: number
}

export const ComponentName: React.FC<ComponentProps> = (props) => {
  const { value, setValue } = useHook1()
  const { action } = useHook2()

  const handleAction = () => {}

  return (
    <div className="...">
      {/* JSX */}
    </div>
  )
}

Padrão de hook custom:
import { useCallback, useState, useEffect } from 'react'

export const useCustomHook = () => {
  const [state, setState] = useState<Type>(initialValue)

  const action = useCallback(() => {
    // lógica
  }, [dependencies])

  useEffect(() => {
    // efeito
    return () => { /* cleanup */ }
  }, [dependencies])

  return { state, setState, action }
}


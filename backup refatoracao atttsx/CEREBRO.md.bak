5.7 Padrão de Componente com Estado
// Usar hooks para estado, não classes
// Preferir composição a herança

const [clients, setClients] = useState<Client[]>([])
const [loading, setLoading] = useState(false)
const [error, setError] = useState<string | null>(null)

// Usar useMemo para derivações pesadas
const filteredClients = useMemo(() => {
  return clients.filter(c => c.status === 'OVERDUE')
}, [clients])

// Usar useCallback para handlers passados a children
const handleDelete = useCallback((clientId: string) => {
  // lógica
}, [])

5.8 Padrão de Validação
// Validação em service layer quando possível
export function validateClientData(data: Partial<Client>): string[] {
  const errors: string[] = []
  
  if (!data.name?.trim()) errors.push('Nome é obrigatório')
  if (!data.bikeModel?.trim()) errors.push('Modelo da moto é obrigatório')
  if (data.recurrenceDays && data.recurrenceDays < 1) errors.push('Recorrência deve ser ≥ 1 dia')
  
  return errors
}

// No componente
const errors = validateClientData(formData)
if (errors.length > 0) {
  toast.error(errors.join('; '))
  return
}


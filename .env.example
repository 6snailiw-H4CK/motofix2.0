# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# === FIREBASE CONFIGURAÇÃO ===
# Obtenha em: https://console.firebase.google.com → Project Settings
VITE_FIREBASE_API_KEY=sua_chave_api_firebase
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_numero
VITE_FIREBASE_APP_ID=seu_app_id

# === STRIPE CONFIGURAÇÃO ===
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=coloque_a_publishable_key_aqui
STRIPE_SECRET_KEY=coloque_a_secret_key_apenas_no_backend
STRIPE_WEBHOOK_SECRET=coloque_o_webhook_secret_apenas_no_backend
STRIPE_PRICE_ID=price_seu_price_id_aqui

# === FIREBASE ADMIN SDK ===
# Caminho para o arquivo JSON com credenciais de serviço
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# === SERVIDOR ===
NODE_ENV=development
PORT=3001
VITE_STRIPE_API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
JSON_BODY_LIMIT=512kb
FISCAL_BODY_LIMIT=6mb
WEBHOOK_BODY_LIMIT=2mb
API_RATE_LIMIT_GLOBAL_PER_MINUTE=300
API_RATE_LIMIT_ROUTE_PER_MINUTE=120
WHATSAPP_CONNECT_RATE_LIMIT_PER_10_MINUTES=5
WHATSAPP_SEND_RATE_LIMIT_PER_MINUTE=30
FISCAL_COMPANY_WRITE_RATE_LIMIT_PER_10_MINUTES=20
FISCAL_CERTIFICATE_RATE_LIMIT_PER_15_MINUTES=3
FISCAL_NFSE_RATE_LIMIT_PER_5_MINUTES=12
PAYMENTS_CHECKOUT_RATE_LIMIT_PER_15_MINUTES=10
PAYMENTS_SESSION_RATE_LIMIT_PER_MINUTE=60

# === FISCAL / FOCUS NFE ===
# O frontend usa o mesmo host por padrao. Configure apenas se a API fiscal ficar em outro dominio.
VITE_FISCAL_API_URL=http://localhost:3001

# URLs padrao da Focus NFe. Ajuste somente se a Focus alterar ambientes ou se usar proxy.
FOCUS_NFE_HOMOLOGATION_URL=https://homologacao.focusnfe.com.br
FOCUS_NFE_PRODUCTION_URL=https://api.focusnfe.com.br
FOCUS_NFE_TIMEOUT_MS=20000

# === WHATSAPP / OPEN-WA ===
# O frontend usa o mesmo host por padrao. Configure apenas se a API WhatsApp ficar em outro dominio.
VITE_WHATSAPP_API_URL=http://localhost:3001
WHATSAPP_SESSION_PREFIX=motofix
WHATSAPP_HEADLESS=true
WHATSAPP_USE_CHROME=true
WHATSAPP_CHROME_PATH=
WHATSAPP_CUSTOM_USER_AGENT=
WHATSAPP_SESSION_DATA_PATH=./storage/whatsapp-sessions
WHATSAPP_RESET_ON_TIMEOUT=true
WHATSAPP_QR_TIMEOUT=0
WHATSAPP_AUTH_TIMEOUT=0
WHATSAPP_QR_REFRESH_SECONDS=15
WHATSAPP_WAIT_FOR_RIPE_SESSION_TIMEOUT=0
WHATSAPP_LOG_CONSOLE_ERRORS=false
WHATSAPP_SCREENSHOT_ON_ERROR=false
WHATSAPP_MAX_MESSAGE_LENGTH=4000

# === WHATSAPP / IA ===
# Opcional. Sem chave configurada, a automacao por IA fica inativa.
WHATSAPP_AI_API_KEY=
WHATSAPP_AI_MODEL=gpt-4o-mini
WHATSAPP_AI_API_URL=https://api.openai.com/v1/chat/completions
WHATSAPP_AI_MAX_INPUT_LENGTH=2500
WHATSAPP_AI_MAX_REPLY_LENGTH=900
